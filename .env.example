# Copy this file to .env and fill in values.

# Flask
SECRET_KEY=your-secret-key-here
FLASK_ENV=development

# Database (optional, defaults to sqlite data/resumeai.db)
DATABASE_URL=

# Resume parsing / matching
JSEARCH_API_KEY=

# AI optimizer (Gemini)
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash
OPTIMIZE_RATE_LIMIT=20 per hour

# Email notifications (optional)
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_NAME=ResumeAI

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twilio SMS OTP (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
